.icon-preview-page {
  padding-bottom: 60rpx;
}

.preview-title {
  margin-bottom: 18rpx;
  color: #333333;
  font-size: 32rpx;
  font-weight: 700;
}

.preview-title.compact {
  margin-top: 36rpx;
}

.preview-note {
  margin-bottom: 24rpx;
  color: #777777;
  font-size: 22rpx;
  line-height: 1.35;
}

.sample-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 18rpx 0;
}

.sample-card {
  width: 31.5%;
  min-height: 176rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #eaeaea;
  border-radius: 8rpx;
}

.svg-tab-icon {
  width: 86rpx;
  height: 86rpx;
  display: block;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.svg-tab-icon.small {
  width: 42rpx;
  height: 42rpx;
  margin-bottom: 8rpx;
}

.sample-label {
  margin-top: 12rpx;
  color: #666666;
  font-size: 20rpx;
  font-weight: 700;
}

.tabbar-path-demo {
  height: 152rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: #eaeaea;
}

.tabbar-slot {
  flex: 1;
  height: 152rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tabbar-label {
  color: #939393;
  font-size: 20rpx;
  line-height: 1.1;
}

.tabbar-label.active {
  color: #82947b;
}

