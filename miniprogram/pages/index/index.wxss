/* 首页整屏底板：min-height 控制至少占满屏幕，background 控制页面底色。 */
.home-page {
  min-height: 100vh;
  background: var(--color-page-bg);
  box-sizing: border-box;
}

/* 预留自定义导航区：display 改为 flex/block 后会出现页顶品牌标题。 */
.home-nav {
  display: none;
}

/* 自定义导航标题：max-width/字号/截断方式影响顶部标题可见长度。 */
.home-nav-title {
  max-width: 100%;
  color: #111111;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 首页主体边距：padding 的四个方向分别控制首屏上方、左右及 tabBar 上方留白。 */
.home-content {
  padding: 98rpx 30rpx 190rpx;
  box-sizing: border-box;
}

/* 品牌头区域：min-height 和 margin-bottom 控制 Logo 行高度及与下方搜索操作行的距离。 */
.home-brand {
  position: relative;
  min-height: 62rpx;
  margin-bottom: 22rpx;
}

/* Logo 定位与占宽：margin-top、padding-left、width 调整品牌在首屏的大小和位置。 */
.home-brand .brand-lockup {
  margin-top: -10rpx;
  padding-left: 22rpx;
  width: 230rpx;
}

/* 实际 Logo 图片宽度：与上方容器 width 同步调整可避免变形或溢出。 */
.home-brand .brand-logo-vector {
  width: 230rpx;
  height: 65rpx;
  display: block;
}

/* 保留给文字品牌版本的主标题字号与行高。 */
.home-brand .brand-main {
  font-size: 34rpx;
  line-height: 0.92;
}

/* 保留给文字品牌版本的副标题偏移和字号。 */
.home-brand .brand-sub {
  margin-left: 106rpx;
  margin-top: 4rpx;
  font-size: 20rpx;
}

/* Logo 弹性容器：flex/min-width 决定品牌与重置按钮的可用水平空间。 */
.brand-lockup {
  flex: 1;
  min-width: 0;
}

/* 搜索操作行：gap 控制搜索栏与右侧重置按钮的水平间距，margin-bottom 控制与上传框间距。 */
.search-row {
  margin-bottom: 22rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 搜索栏右侧重置按钮：height 与 `.search-box` 保持一致，按钮在内容区内不会被胶囊按钮遮挡。 */
.reset-button {
  flex: 0 0 auto;
  margin-left: auto;
  min-width: 105rpx;
  height: 40rpx;
  padding: 0 13rpx;
  gap: 4rpx;
  border-radius: 7rpx;
  font-size: 21rpx;
}

/* 重置图标大小：同时修改宽高以保持正方形。 */
.reset-icon {
  width: 24rpx;
  height: 24rpx;
}

/* 文本搜索框：flex 决定它占满重置按钮左侧空间，height/padding/gap 控制内容位置。 */
.search-box {
  flex: 1;
  min-width: 0;
  height: 52rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: var(--color-upload-bg);
  border: 2rpx dashed var(--color-line);
  border-radius: 8rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7), 0 2rpx 0 rgba(0, 0, 0, 0.02);
  box-sizing: border-box;
}

/* 搜索图标尺寸。 */
.search-icon {
  width: 28rpx;
  height: 28rpx;
}

/* 输入文字外观：height/line-height 应同步修改以保持垂直居中。 */
.search-input {
  flex: 1;
  height: 50rpx;
  color: var(--color-text-strong);
  font-size: 24rpx;
  font-weight: 500;
  line-height: 50rpx;
}

/* 搜索占位文案颜色与字重。 */
.search-placeholder {
  color: var(--color-text-muted);
  font-weight: 500;
}

/* 图片上传主框：height 决定首屏占比，margin-bottom 决定与分类条的间距。 */
.upload-box {
  position: relative;
  height: 354rpx;
  margin-bottom: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: var(--color-upload-bg);
  border: 2rpx dashed var(--color-line);
  border-radius: 8rpx;
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
}

/* 上传框按下反馈：background 和位移控制点击触感。 */
.upload-box:active {
  background: #dddddd;
  transform: translateY(1rpx);
}

/* 已选图片状态下内容居中方式。 */
.upload-box-filled {
  justify-content: center;
}

/* 空状态相机图标尺寸。 */
.upload-camera-icon {
  width: 58rpx;
  height: 50rpx;
}

/* 空状态主提示：margin/font-size/font-weight 控制标题层级。 */
.upload-title {
  margin-top: 18rpx;
  color: #3d3d3d;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0;
  line-height: 1.18;
  text-align: center;
}

/* 空状态副提示：margin/font-size/color 控制辅助文案层级。 */
.upload-sub {
  margin-top: 8rpx;
  color: var(--color-text-muted);
  font-size: 18rpx;
  font-weight: 800;
  line-height: 1.2;
  text-align: center;
}

/* 上传预览图：width/height 定义花色预览比例，border-radius 控制圆角。 */
.upload-preview {
  width: 240rpx;
  height: 306rpx;
  display: block;
  border-radius: 8rpx;
}

/* 图片底部更换提示条：bottom/width/height/背景透明度均可按设计微调。 */
.change-strip {
  position: absolute;
  left: 50%;
  bottom: 18rpx;
  transform: translateX(-50%);
  width: 240rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #878787;
  background: rgba(255, 255, 255, 0.62);
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 800;
}

/* 图片右下裁剪按钮：right/bottom 控制锚点，尺寸和字号控制可点击面积。 */
.crop-button {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  min-width: 120rpx;
  height: 38rpx;
  padding: 0 12rpx;
  color: #868686;
  background: rgba(255, 255, 255, 0.72);
  border-radius: 7rpx;
  font-size: 20rpx;
  font-weight: 700;
}

/* 折叠预览模式的对齐方式。 */
.upload-box-compact {
  align-items: center;
  justify-content: center;
}

/* 折叠预览左上说明标签位置与字号。 */
.image-fold-label {
  position: absolute;
  top: 16rpx;
  left: 24rpx;
  z-index: 2;
  color: #333333;
  font-size: 22rpx;
  font-weight: 700;
}

/* 折叠预览图尺寸。 */
.compact-preview {
  width: 240rpx;
  height: 306rpx;
}

/* 已收起图片的一行入口：height/margin/padding 控制结果页保留的图片入口高度。 */
.image-fold-strip {
  height: 54rpx;
  margin-bottom: 24rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  color: #333333;
  background: var(--color-upload-bg);
  border: 2rpx dashed var(--color-line);
  border-radius: 8rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7);
  box-sizing: border-box;
  font-size: 22rpx;
  font-weight: 700;
}

/* 辅助分类横向分段控件：margin 控制与上下区块距离，圆角控制整体轮廓。 */
.segment {
  margin: 0 8rpx 21rpx;
  display: flex;
  align-items: stretch;
  overflow: hidden;
  border-radius: 8rpx;
  justify-content: flex-start;
}

/* 分类标题与选项共用高度/边框/文字对齐参数。 */
.segment-label,
.segment-item {
  height: 40rpx;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--color-line);
  box-sizing: border-box;
  text-align: center;
  line-height: 1.08;
}

/* 分类控件左侧标题：flex-basis 控制其宽度，颜色和字号控制视觉权重。 */
.segment-label {
  flex: 0 0 150rpx;
  padding: 0 8rpx;
  color: #ffffff;
  background: #9a9a9a;
  font-size: 19rpx;
  font-weight: 800;
}

/* 单项分类按钮：flex-basis 控制每项宽度，padding 影响长文案空间。 */
.segment-item {
  flex: 0 0 90rpx;
  margin-left: -1rpx;
  padding: 0 6rpx;
  color: #2d2d2d;
  background: #ffffff;
  font-size: 19rpx;
  font-weight: 700;
}

/* 当前选中分类的背景色与文字色。 */
.segment-item.active {
  position: relative;
  z-index: 1;
  color: #ffffff;
  background: var(--color-primary-soft);
  border-color: var(--color-primary-soft);
}

/* 匹配方式面板：padding 控制内容留白，background 控制面板弱化程度。 */
.mode-panel {
  margin-top: 0;
  padding: 22rpx 20rpx 24rpx;
  background: rgba(247, 247, 245, 0.62);
}

/* 匹配方式标题字号覆盖。 */
.mode-panel .section-title {
  font-size: 24rpx;
}

/* 单个匹配方式行：margin-top 与 gap 控制行间距离和圆点到文字的距离。 */
.mode-row {
  margin-top: 34rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 未选单选圆：width/height/border 调整触点大小与线条粗细。 */
.radio {
  width: 28rpx;
  height: 28rpx;
  border: 2rpx solid var(--color-primary-soft);
  border-radius: 50%;
  box-sizing: border-box;
}

/* 已选单选圆中心：width/height/margin 应协调调整以居中。 */
.radio.checked::after {
  content: "";
  width: 16rpx;
  height: 16rpx;
  margin: 4rpx;
  display: block;
  background: var(--color-primary-soft);
  border-radius: 50%;
}

/* 模式文案横向/换行布局：flex-wrap 决定说明是否可换行。 */
.mode-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
}

/* 匹配方式名称字号与字重。 */
.mode-name {
  color: var(--color-text-strong);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
}

/* 匹配方式补充说明的偏移、颜色及字号。 */
.mode-desc {
  margin-left: 8rpx;
  color: var(--color-text-muted);
  font-size: 18rpx;
  font-weight: 800;
  line-height: 1.2;
}

/* 主搜索按钮首页覆盖：width/height/margin 是按钮宽高及首屏纵向位置。 */
.start-button {
  width: 385rpx;
  height: 87rpx;
  margin-top: 96rpx;
  margin-bottom: 36rpx;
  font-size: 28rpx;
}

/* 主按钮右侧箭头白块的尺寸和右间距。 */
.start-button .button-arrow {
  width: 73rpx;
  height: 73rpx;
  margin-right: 7rpx;
  background-color: transparent;
  background-size: contain;
}

/* 箭头图形尺寸。 */
.start-button .button-arrow .ui-icon {
  width: 34rpx;
  height: 34rpx;
}

/* 请求中的状态提示：负上边距和下边距影响其与结果区的距离。 */
.status-line {
  margin: -16rpx 0 34rpx;
  color: #777777;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
}

/* 结果标题栏：margin 控制标题离上方控件及卡片网格的距离。 */
.results-head {
  margin: 20rpx 2rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 图片识别有结果时标题栏的额外上间距。 */
.results-head-image {
  margin-top: 38rpx;
}

/* 查询结果数量文字字号与字重。 */
.result-count {
  color: var(--color-text-strong);
  font-size: 26rpx;
  font-weight: 800;
}

/* 结果主标题字号覆盖。 */
.results-head .section-title {
  font-size: 30rpx;
  line-height: 1.15;
}

/* 卡片内名称/编号文本可用空间。 */
.pattern-copy {
  flex: 1;
  min-width: 0;
}

/* 首页花色卡片覆盖：width 决定两列间距，margin-bottom 决定行距。 */
.pattern-card {
  width: 48.6%;
  margin-bottom: 22rpx;
  border-radius: 8rpx;
  box-shadow: none;
}

/* 首页花色图片高度：改变缩略图纵横比例的主要参数。 */
.pattern-image {
  height: 374rpx;
}

/* 卡片底部信息条：height/padding/gap 控制名称和“更多颜色”的密度。 */
.pattern-meta {
  min-height: 66rpx;
  padding: 7rpx 10rpx 8rpx;
  gap: 10rpx;
}

/* 花色名称可见长度、字号和行高。 */
.pattern-name {
  max-width: 118rpx;
  font-size: 22rpx;
  line-height: 1.05;
}

/* 花色编号的间距与字号。 */
.pattern-code {
  margin-top: 2rpx;
  font-size: 18rpx;
  line-height: 1.1;
}

/* “更多颜色”按钮的最小宽度、高度、圆角和字号。 */
.more-button {
  min-width: 106rpx;
  height: 35rpx;
  padding: 0 9rpx;
  border-radius: 7rpx;
  font-size: 19rpx;
}

/* 卡片图片上的分类标签位置及文字大小。 */
.pattern-tag {
  right: 8rpx;
  bottom: 106rpx;
  min-width: 64rpx;
  min-height: 36rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border-radius: 4rpx;
  font-size: 19rpx;
  line-height: 1;
}

/* 小图右上收藏按钮的触摸范围与定位。 */
.star {
  top: 10rpx;
  right: 10rpx;
  width: 50rpx;
  height: 50rpx;
}

/* 收藏星形图标显示尺寸。 */
.star .star-icon {
  width: 46rpx;
  height: 46rpx;
}
