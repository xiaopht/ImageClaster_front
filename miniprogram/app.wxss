/* 全局主题参数：这里集中修改页面底色、品牌绿、文字色、线条色、收藏黄和全局字体。 */
page {
  --color-page-bg: #f5f5f5;
  --color-soft-page-bg: #f7f7f5;
  --color-panel-bg: #e2e2e2;
  --color-upload-bg: #e2e2e2;
  --color-tabbar-bg: #eaeaea;
  --color-primary: #82947a;
  --color-primary-soft: #84977c;
  --color-primary-dark: #74866d;
  --color-text-strong: #333333;
  --color-text-muted: #8d8d8d;
  --color-text-light: #ffffff;
  --color-line: #999999;
  --color-card: #ffffff;
  --color-tag-dark: rgba(72, 72, 72, 0.68);
  --color-mask: rgba(0, 0, 0, 0.66);
  --color-star: #e3c96f;
  --font-family-base: "HarmonyOS Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif;
  --font-family-title: var(--font-family-base);
  --font-family-body: var(--font-family-base);
  --font-family-number: var(--font-family-base);
  --font-family-button: var(--font-family-base);

  min-height: 100vh;
  background: var(--color-page-bg);
  color: var(--color-text-strong);
  font-size: 28rpx;
  line-height: 1.35;
  font-family: var(--font-family-body);
}

/* 通用页面容器：padding 控制拍摄页等标准页面距离边缘与底部 tabBar 的留白。 */
.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 42rpx 30rpx 170rpx;
}

/* 所有按钮基础外观：圆角、默认字号和字体会影响全站按钮。 */
button {
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  border: 0;
  font-size: 28rpx;
  line-height: 1;
  font-family: var(--font-family-button);
}

/* 移除微信按钮自带边框，以设计稿按钮底色/圆角为准。 */
button::after {
  border: 0;
}

/* 表单输入字体：修改后反馈、联系、注册输入框会统一变化。 */
input,
textarea {
  font-family: var(--font-family-body);
}

/* CSS 图标基础盒子：width/height 以调用者的字号或单独覆盖尺寸为准。 */
.ui-icon {
  display: block;
  flex: 0 0 auto;
  width: 1em;
  height: 1em;
  background-position: center;
  background-repeat: no-repeat;
  background-size: contain;
}

/* 内联 SVG 图标资源：替换下列 background-image 可改变搜索、按钮、收藏和翻页的实际图形/颜色。 */
