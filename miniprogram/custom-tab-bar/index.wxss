@import "../styles/svg-path-icons.wxss";

.custom-tabbar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 999;
  height: 152rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: #eaeaea;
  box-sizing: border-box;
}

.custom-tabbar-item {
  flex: 1;
  height: 152rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #939393;
  font-size: 20rpx;
  line-height: 1.1;
}

.custom-tabbar-item.active {
  color: #82947b;
}

.custom-tabbar-icon {
  width: 42rpx;
  height: 42rpx;
  margin-bottom: 8rpx;
  background-position: center;
  background-repeat: no-repeat;
  background-size: contain;
}

.custom-tabbar-label {
  font-size: 20rpx;
  font-weight: 500;
}
